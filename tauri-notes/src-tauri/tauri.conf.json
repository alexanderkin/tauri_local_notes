{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Notes",
  "version": "0.1.1",
  "identifier": "com.kin.taurinotes",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "本地笔记本",
        "width": 900,
        "height": 700,
        "minWidth": 700,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
